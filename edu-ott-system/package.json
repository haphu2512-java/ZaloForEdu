{
  "name": "edu-ott-system",
  "version": "1.0.0",
  "description": "Education OTT Platform - Hệ thống OTT giáo dục",
  "private": true,
  "workspaces": [
    "backend",
    "frontend/web",
    "frontend/mobile"
  ],
  "scripts": {
    "backend": "cd backend && npm run dev",
    "web": "cd frontend/web && npm run dev",
    "mobile": "cd frontend/mobile && npm start",
    "install:all": "npm install && cd backend && npm install && cd ../frontend/web && npm install && cd ../mobile && npm install",
    "clean": "rm -rf node_modules backend/node_modules frontend/web/node_modules frontend/mobile/node_modules",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces"
  },
  "keywords": [
    "education",
    "ott",
    "chat",
    "learning-management",
    "react",
    "react-native",
    "nodejs",
    "express"
  ],
  "author": "Your Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.14.0",
    "dom": "^0.0.3",
    "lucide-react": "^1.7.0",
    "react-router": "^7.14.0"
  }
}