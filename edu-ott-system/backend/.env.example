PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://admin:password123@127.0.0.1:27017/edu-ott-db?authSource=admin
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:19006
JWT_SECRET=your_access_secret
JWT_REFRESH_SECRET=your_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REDIS_URL=redis://127.0.0.1:6379
REDIS_PREFIX=ott
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_ENABLE_OFFLINE_QUEUE=true
TYPING_TTL_SECONDS=15
UPLOADS_DIR=uploads
LOG_LEVEL=info

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_FOLDER=ott-messaging
CLOUDINARY_SIGNATURE_TTL_SECONDS=60

# SMTP CONFIG
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Zalo Clone <your_email@gmail.com>"
SMTP_ALLOW_UNAUTHORIZED=false
SMTP_USE_ETHEREAL=true

# AI Chatbot (Optional)
OPENAI_API_KEY=your-openai-api-key
CHATBOT_MODEL=gpt-3.5-turbo
