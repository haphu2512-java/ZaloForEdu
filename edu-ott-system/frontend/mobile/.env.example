# API Configuration
# For local dev, Expo auto-detects the bundler IP.
# Set these for staging / production deployments:
EXPO_PUBLIC_API_URL=
EXPO_PUBLIC_SOCKET_URL=

# For Android Emulator use: http://10.0.2.2:5000
# For iOS Simulator use: http://localhost:5000
# For Physical Device use: http://YOUR_LOCAL_IP:5000

# App Configuration
APP_NAME=Education OTT Platform
APP_VERSION=1.0.0
EXPO_PUBLIC_DEFAULT_THEME=dark

# File Upload
MAX_FILE_SIZE=10485760

# Features
ENABLE_VIDEO_CALL=true
ENABLE_AI_CHATBOT=true
