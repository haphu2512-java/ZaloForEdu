# API Configuration
VITE_API_URL=http://localhost:5000/api/v1
VITE_SOCKET_URL=http://localhost:5000

# App Configuration
VITE_APP_NAME=Education OTT Platform
VITE_APP_VERSION=1.0.0

# File Upload
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=image/*,video/*,application/pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx

# Features
VITE_ENABLE_VIDEO_CALL=true
VITE_ENABLE_AI_CHATBOT=true

# Analytics (optional)
VITE_GOOGLE_ANALYTICS_ID=
